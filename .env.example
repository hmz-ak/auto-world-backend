# Application runtime environment: development, test, or production.
NODE_ENV=development

# Port where the NestJS API listens.
PORT=3000

# Comma-separated frontend origins allowed to send credentialed requests.
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# PostgreSQL server host.
DB_HOST=localhost

# PostgreSQL server port.
DB_PORT=5432

# PostgreSQL user used by the application.
DB_USERNAME=postgres

# PostgreSQL password used by the application.
DB_PASSWORD=your_postgres_password

# PostgreSQL database name used by Auto World.
DB_NAME=auto_world

# Secret used to sign JWT cookies. Use a long random value in real environments.
JWT_SECRET=change_this_to_a_long_random_secret_string

# JWT session lifetime.
JWT_EXPIRES_IN=8h

# Company name printed on receipts.
COMPANY_NAME=Auto World

# Company address printed on receipts.
COMPANY_ADDRESS=Lahore, Pakistan

# Company phone printed on receipts.
COMPANY_PHONE=+92-XXX-XXXXXXX
